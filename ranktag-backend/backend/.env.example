# ── App ──
APP_ENV=development            # development | staging | production
LOG_LEVEL=INFO
LOG_JSON=false                 # true in production for structured JSON logs

# ── Server ──
HOST=0.0.0.0
PORT=8000
WORKERS=1                      # gunicorn workers; (2 * CPU) + 1 in prod

# ── CORS (comma-separated origins) ──
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Redis (leave empty to use the in-memory cache/session fallback) ──
REDIS_URL=
CACHE_TTL=3600
CACHE_MAX_ENTRIES=50000

# ── Database (prepared but not required by the current backend) ──
DATABASE_URL=

# ── Rate limiting (per client IP) ──
RATE_LIMIT_RPM=60
RATE_LIMIT_BURST=10

# ── Limits / NLP ──
MAX_CONTENT_LENGTH=500000
MAX_COMPETITOR_URLS=10
REQUEST_TIMEOUT=60
SPACY_MODEL=en_core_web_sm

# ── Production example ──
# APP_ENV=production
# LOG_JSON=true
# REDIS_URL=redis://localhost:6379/0
# ALLOWED_ORIGINS=https://rankedtag.com
# WORKERS=4
