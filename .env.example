# ─────────────────────────────────────────────────────────────────────────
# GTMx — local environment. Copy to .env.local and fill in real values.
# .env* files are gitignored (except this example). Production values live in
# Vercel → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────

# ── Neon / Vercel Postgres (dashboards + blog CMS) ──────────────────────
# Server-only connection string. On Vercel, add the Neon integration and this
# is injected automatically (as DATABASE_URL). Locally, copy the *pooled*
# connection string from the Neon Console → Connect. Never expose to the browser.
DATABASE_URL=

# ── Vercel Blob (blog CMS image uploads) ────────────────────────────────
# Injected automatically once a Blob store is connected in Vercel → Storage.
# Locally, copy it from the Blob store's .env tab (or `vercel env pull`).
BLOB_READ_WRITE_TOKEN=

# ── Blog CMS admin (/admin) ─────────────────────────────────────────────
# Password for signing in to the CMS. A built-in default is used if unset,
# but override it in production (this repo may be public).
ADMIN_PASSWORD=
# Optional: decouples the session-signing key from the password. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ADMIN_SESSION_SECRET=

# ── Cron (Supabase sync) ────────────────────────────────────────────────
# Vercel sends `Authorization: Bearer <CRON_SECRET>` to /api/cron/sync.
CRON_SECRET=
